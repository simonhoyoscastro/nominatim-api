# OSM extract to import. Defaults to Colombia; point at any Geofabrik .osm.pbf
# to cover a different country/region instead.
PBF_URL=https://download.geofabrik.de/south-america/colombia-latest.osm.pbf

# Password Nominatim uses internally to connect to its own Postgres database.
NOMINATIM_PASSWORD=changeme

# Optional. If set, GET /postcode requires a matching X-API-Key header.
# Leave blank for unauthenticated local development.
API_KEY=

# Port the wrapper API listens on. Railway injects its own PORT automatically.
PORT=8000
